# ===== Secrets — NEVER commit =====
.env
*.env
!.env.example

# ===== Python =====
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
venv/
.venv/
env/

# ===== Runtime data / logs =====
logs/
*.log
# databases hold live app data; keep them out of git (they change constantly)
*.db
*.sqlite
*.sqlite3

# ===== Flutter / Dart / Android build artifacts =====
akeriyan_app/.dart_tool/
akeriyan_app/.flutter-plugins
akeriyan_app/.flutter-plugins-dependencies
akeriyan_app/build/
**/build/
.gradle/
*.iml
local.properties

# ===== Large ML assets / scratch =====
# NOTE: wakeword_training/real_samples/ IS tracked — the ~1 MB of real user
# voice recordings are essential training data the Colab notebook pulls in.
*.tmp

# ===== Vendored binaries & models (large & downloadable, keep out of git) =====
# NOTE: the app's own wakeword models (assets/wakeword/*.tflite, ~3 MB total)
# ARE tracked — they're small and essential. Only the big vendored stuff below
# is excluded via explicit paths, so we don't need blanket *.tflite / *.onnx.
*.zip
# Piper TTS runtime (binaries, dll, espeak data, onnx/ort voices)
akeriyan_backend/piper/
# Vosk / local model assets (40 MB zip)
akeriyan_app/assets/models/
# tflite_flutter third-party native libs + example junk (multi-MB, not our code)
akeriyan_app/third_party/tflite_flutter/example/
**/libtensorflowlite_c-*.dylib
**/libtensorflowlite_c-*.so
**/*.dll
# Fonts are large binaries; uncomment if you'd rather track them
# *.ttf

# ===== OS =====
Thumbs.db
.DS_Store
desktop.ini
